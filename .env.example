# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service role key for server-side operations (more permissions)
# Only use this in server-side code, never expose it to the client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Better Auth (dashboard login/signup)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret
# App URL (dev: http://localhost:3000, prod: https://yourproduct.com)
BETTER_AUTH_URL=http://localhost:3000
# Database URL for Better Auth tables (use Supabase connection string from Project Settings > Database)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
